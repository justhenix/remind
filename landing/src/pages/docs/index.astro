---
import '../../styles/global.css';

const sections = [
  { id: 'overview', label: 'Overview' },
  { id: 'install', label: 'Install & setup' },
  { id: 'how', label: 'How it works' },
  { id: 'tools', label: 'MCP tools' },
  { id: 'inference', label: 'Repo inference' },
  { id: 'byok', label: 'BYOK' },
  { id: 'dashboard', label: 'Dashboard' },
  { id: 'cli', label: 'CLI reference' },
  { id: 'trouble', label: 'Troubleshooting' },
];
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>remindy docs</title>
    <meta name="description" content="How to install, run, and use remindy, the portable taste & standards layer for AI coding agents." />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <style>
      .doc-shell { display: grid; grid-template-columns: 220px 1fr; gap: 48px; }
      .doc-nav { position: sticky; top: 24px; align-self: start; display: flex; flex-direction: column; gap: 2px; }
      .doc-nav a { font-size: 13px; color: var(--muted); padding: 6px 10px; border-left: 1px solid var(--color-line); text-decoration: none; transition: color .15s, border-color .15s; }
      .doc-nav a:hover, .doc-nav a.active { color: var(--ink); border-color: var(--ink); }
      .doc-section { margin-bottom: 64px; scroll-margin-top: 24px; }
      .doc-section h2 { font-family: var(--font-hero); font-weight: 600; font-size: 26px; letter-spacing: -0.02em; margin-bottom: 14px; }
      .doc-section h3 { font-weight: 600; font-size: 15px; margin: 22px 0 8px; }
      .doc-section p, .doc-section li { color: var(--muted); font-size: 14.5px; line-height: 1.65; }
      .doc-section ul { padding-left: 18px; margin: 8px 0; display: flex; flex-direction: column; gap: 4px; }
      .doc-section strong { color: var(--ink); font-weight: 600; }
      .code { position: relative; background: #161616; border: 1px solid var(--color-line); border-radius: 6px; padding: 14px 16px; margin: 12px 0; overflow-x: auto; }
      .code pre { margin: 0; font-family: 'Host Grotesk', monospace; font-size: 13px; line-height: 1.6; color: var(--ink); white-space: pre; }
      .kv { display: grid; grid-template-columns: 160px 1fr; gap: 6px 16px; margin: 12px 0; font-size: 14px; }
      .kv code { color: var(--ink); font-weight: 600; }
      .kv span { color: var(--muted); }
      .tagchip { display: inline-block; padding: 1px 7px; border-radius: 3px; font-size: 10px; font-weight: 700; color: #FDFFF8; letter-spacing: 0.04em; }
      .callout { border: 1px solid var(--color-line); border-left: 2px solid var(--square-glow); border-radius: 4px; padding: 12px 14px; margin: 14px 0; font-size: 13.5px; color: var(--muted); }
      @media (max-width: 860px) { .doc-shell { grid-template-columns: 1fr; } .doc-nav { position: static; flex-direction: row; flex-wrap: wrap; margin-bottom: 24px; } }
    </style>
  </head>
  <body class="min-h-screen">
    <div class="canvas-grid" aria-hidden="true"></div>

    <header class="relative z-10 w-full max-w-5xl mx-auto flex justify-between items-center px-6 py-5">
      <a href="/" class="flex items-baseline gap-3" style="text-decoration:none;">
        <span class="font-logo text-xl tracking-tight lowercase" style="font-weight:700; color:var(--ink);">remindy</span>
        <span class="hidden sm:inline text-xs text-[var(--muted)]">docs</span>
      </a>
      <nav class="flex items-center gap-6 text-xs text-[var(--muted)]">
        <a href="/" class="hover:text-[var(--ink)] transition-colors">home</a>
        <a href="https://github.com/justhenix/remindy" class="hover:text-[var(--ink)] transition-colors">github</a>
      </nav>
    </header>

    <main class="relative z-10 w-full max-w-5xl mx-auto px-6 pt-6 pb-24">
      <div class="mb-12">
        <span class="eyebrow mb-3 block">documentation</span>
        <h1 class="font-hero text-4xl md:text-5xl tracking-tight leading-[1.05] mb-4" style="font-weight:600;">
          Set your standards once.<br />Enforced everywhere.
        </h1>
        <p class="text-[15px] text-[var(--muted)] max-w-xl leading-relaxed">
          remindy is an MCP server your editor runs for you. It feeds your coding standards
          to any AI agent before it writes, and remembers corrections across every tool.
          Everything runs on your machine.
        </p>
      </div>

      <div class="doc-shell">
        <aside class="doc-nav" id="doc-nav">
          {sections.map((s) => <a href={`#${s.id}`} data-id={s.id}>{s.label}</a>)}
        </aside>

        <div>
          <section id="overview" class="doc-section">
            <h2>Overview</h2>
            <p>
              Linters catch syntax. remindy catches <strong>taste</strong>: AI-slop copy, inline
              styles, non-conventional commits, hardcoded secrets, unrequested features. These are
              subjective standards a linter can't catch. You teach it once; it holds every AI agent to
              those standards for about 15 tokens a turn.
            </p>
            <h3>Why it's portable</h3>
            <p>
              remindy speaks the Model Context Protocol, so a correction made in one tool (say
              Cursor) is respected by another (Kiro, Claude, Windsurf). The shared memory lives on
              your machine via <strong>Supermemory Local</strong>.
            </p>
          </section>

          <section id="install" class="doc-section">
            <h2>Install &amp; setup</h2>
            <h3>1. Start Supermemory Local</h3>
            <p>The shared store. It's a Unix binary; on Windows run it inside WSL2.</p>
            <div class="code"><pre>curl -fsSL https://supermemory.ai/install | bash
supermemory-server   # listens on http://localhost:6767</pre></div>
            <p>Copy the API key it prints into your <code>.env</code> as <code>SUPERMEMORY_API_KEY</code>.</p>
            <h3>2. Initialise remindy in your project</h3>
            <div class="code"><pre>npx remindy init --seed</pre></div>
            <p>
              This registers the remindy MCP server in every detected editor, drops a one-line
              project rule, and seeds standards inferred from your repo.
            </p>
            <h3>3. Reload your editor</h3>
            <p>Your editor spawns the MCP server. That's it. Now just code with your agent.</p>
            <div class="callout">
              remindy is not a CLI you keep running. After <code>init</code> it lives inside your
              editor as an MCP server. The CLI is only for setup, seeding, and the dashboard.
            </div>
          </section>

          <section id="how" class="doc-section">
            <h2>How it works</h2>
            <p>Two tools run the loop, on every code write:</p>
            <ul>
              <li><strong>recall</strong>: before writing, the agent pulls your known standards, ranked by relevance and how often each was corrected, trimmed to a ~100-token budget.</li>
              <li><strong>capture</strong>: when you correct the agent, the correction is compressed to a one-line rule and stored (or its burn count is bumped if it already exists).</li>
            </ul>
            <h3>Caveman rule format</h3>
            <div class="code"><pre>[TAG] anti-pattern &rarr; fix (&times;N)</pre></div>
            <p>
              <span class="tagchip" style="background:#c0453b;">SEC</span>
              &nbsp;<code style="color:var(--ink);">secrets in code &rarr; env vars + gitignore (&times;3)</code>
            </p>
            <p>Tags: UI, COPY, CODE, COMMIT, SEC, REQ, PERF. The <code>&times;N</code> burn count drives ranking.</p>
          </section>

          <section id="tools" class="doc-section">
            <h2>MCP tools</h2>
            <h3>remindy_recall</h3>
            <div class="kv">
              <code>input</code><span>task_context: string</span>
              <code>returns</code><span>{'{'} rules: string[], tokens: number {'}'}</span>
            </div>
            <p>Called before writing or editing code. Returns the known standards to avoid.</p>
            <h3>remindy_capture</h3>
            <div class="kv">
              <code>input</code><span>mistake: string, tag?: Tag</span>
              <code>returns</code><span>{'{'} id, caveman, burns {'}'}</span>
            </div>
            <p>Called when the agent is corrected, or invoked directly by you. Compresses, dedups, and stores.</p>
          </section>

          <section id="inference" class="doc-section">
            <h2>Repo inference</h2>
            <p>
              <code>remindy seed</code> scans your repository and infers one standard per tag from
              real signals, so recall is useful on the very first run, no cold start:
            </p>
            <ul>
              <li><strong>UI</strong>: inline styles vs design tokens in your styles</li>
              <li><strong>COPY</strong>: AI-slop words in README / user-facing strings</li>
              <li><strong>CODE</strong>: React derived-state patterns or a loose tsconfig</li>
              <li><strong>SEC</strong>: hardcoded secrets and <code>.env</code> gitignore coverage</li>
              <li><strong>COMMIT</strong>: conventional-commit adherence in your git log</li>
              <li><strong>REQ</strong>: presence of specs / requirements docs</li>
            </ul>
            <p>Where a signal is absent, a curated starter rule fills the gap. Detection is deterministic; the LLM only polishes wording.</p>
          </section>

          <section id="byok" class="doc-section">
            <h2>BYOK: bring your own key</h2>
            <p>Compression runs on any OpenAI-compatible model. Four providers are built in: pick whichever you have a key for:</p>
            <ul>
              <li><strong>Ollama</strong>: local, on-machine, free (default)</li>
              <li><strong>OpenAI</strong>: e.g. gpt-5.6-luna</li>
              <li><strong>Anthropic (Claude)</strong>: via Anthropic's OpenAI-compatible endpoint, e.g. claude-haiku-4-5</li>
              <li><strong>b.ai</strong>: e.g. claude-sonnet-5</li>
            </ul>
            <h3>From the dashboard</h3>
            <p>Open the <strong>provider</strong> panel, pick a provider (fields prefill sensible defaults), paste your key, save. Written only to your gitignored <code>.env</code>.</p>
            <h3>From the CLI</h3>
            <div class="code"><pre>remindy config                 # show current (key masked)
remindy config set --provider openai    --key sk-...     --model gpt-5.6-luna
remindy config set --provider anthropic --key sk-ant-... --model claude-haiku-4-5
remindy config set --provider bai       --key ...        --model claude-sonnet-5
remindy config set --provider ollama    --model qwen2.5-coder:3b</pre></div>
            <div class="callout">Keys never leave your machine and are never logged. Restart the MCP server / editor after changing them.</div>
          </section>

          <section id="dashboard" class="doc-section">
            <h2>Dashboard</h2>
            <div class="code"><pre>npx remindy dashboard   # http://localhost:3456</pre></div>
            <p>A local control room for your taste pack:</p>
            <ul>
              <li>See and inline-edit every stored standard</li>
              <li>Capture a new rule or dry-run recall for any task context</li>
              <li>A backend badge: <strong>green</strong> means live Supermemory (shared + persistent), <strong>red</strong> means isolated in-memory</li>
              <li>The BYOK provider panel</li>
            </ul>
            <p>Click <strong>Tour</strong> in the dashboard for a guided walkthrough.</p>
          </section>

          <section id="cli" class="doc-section">
            <h2>CLI reference</h2>
            <div class="kv">
              <code>remindy init [--seed]</code><span>register MCP server, drop project rule, optionally seed</span>
              <code>remindy seed</code><span>infer + store standards from this repo</span>
              <code>remindy doctor</code><span>check config, LLM, and Supermemory; print active backend</span>
              <code>remindy dashboard</code><span>launch the local dashboard</span>
              <code>remindy config [set]</code><span>view or set the LLM provider (BYOK)</span>
            </div>
          </section>

          <section id="trouble" class="doc-section">
            <h2>Troubleshooting</h2>
            <h3>Backend badge is red / not shared across tools</h3>
            <p>Supermemory Local isn't reachable. Start it, confirm <code>SUPERMEMORY_API_KEY</code> in <code>.env</code> matches the key it printed, then run <code>remindy doctor</code>.</p>
            <h3>Recall returns nothing</h3>
            <p>Run <code>remindy seed</code> to populate the store, or capture a rule from the dashboard.</p>
            <h3>Capture is slow or falls back</h3>
            <p>The LLM provider is unreachable. remindy falls back to a deterministic template so it never blocks, but set a working provider via BYOK for best wording.</p>
          </section>
        </div>
      </div>
    </main>

    <footer class="relative z-10 w-full max-w-5xl mx-auto text-center text-xs text-[var(--muted)] px-6 py-8">
      <p>remindy &middot; powered by <a href="https://supermemory.ai" class="text-[var(--ink)] hover:opacity-70 transition-opacity underline underline-offset-2 decoration-[var(--color-line)]">supermemory.ai</a></p>
    </footer>

    <script is:inline>
      // Highlight the active section in the sidebar as you scroll.
      var links = document.querySelectorAll('.doc-nav a');
      var map = {};
      links.forEach(function (a) { map[a.getAttribute('data-id')] = a; });
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            links.forEach(function (a) { a.classList.remove('active'); });
            var a = map[e.target.id];
            if (a) a.classList.add('active');
          }
        });
      }, { rootMargin: '-10% 0px -80% 0px' });
      document.querySelectorAll('.doc-section').forEach(function (s) { obs.observe(s); });
    </script>
  </body>
</html>
